# =============================================================================
# RuangBaru Workspace — Environment Variables
# Copy this file to .env.local and fill in your actual values
# =============================================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# New-style publishable key (Project Settings → API Keys). Preferred.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
# Legacy anon key — still supported as a fallback if you use the old format.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# New-style secret key (or legacy service_role). Server-only — never expose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=RuangBaru Workspace

# Resend (Transactional Email)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Sentry (Error Tracking)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=ruangbaru
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# PostHog (Product Analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Stripe (Billing - Optional)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
# STRIPE_SECRET_KEY=sk_test_your_key
# STRIPE_WEBHOOK_SECRET=whsec_your_secret

# Groq (Chatbot AI - Optional)
# Free key from https://console.groq.com/keys. Server-only — never exposed to the browser.
# If left unset, the floating chatbot falls back to its built-in knowledge base.
GROQ_API_KEY=gsk_your_groq_api_key
# Optional model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.1-8b-instant

# LiveKit (Meetings)
# From LiveKit Cloud (https://cloud.livekit.io) → Settings → Keys.
# URL is public (browser); KEY/SECRET are server-only and never exposed.
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=API_your_key
LIVEKIT_API_SECRET=your_secret

# Google Calendar (two-way sync — OPTIONAL)
# Inert until both CLIENT_ID and CLIENT_SECRET are set. Create an OAuth 2.0
# Web client at https://console.cloud.google.com/apis/credentials with the
# Google Calendar API enabled, and add the redirect URI below.
# Scopes used: calendar.events, calendar.readonly, openid, email.
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# Defaults to ${NEXT_PUBLIC_APP_URL}/api/google/callback when unset.
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
